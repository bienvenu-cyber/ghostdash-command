{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/public",
  "env": {
    "PORT": "3001",
    "BASE_PATH": "/",
    "NODE_ENV": "production"
  },
  "regions": ["sfo1"],
  "rewrites": [
    {
      "source": "/my/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
